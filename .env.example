# Copy this file to `.env` next to docker-compose.yml. Compose will read it
# automatically. None of these are required — every variable has a sane
# default in docker-compose.yml — but you almost certainly want to set
# DASHBOARD_API_KEY for anything beyond a single-user laptop.

# Bearer token required on every REST + WebSocket request when set.
# Empty (the default) = open mode, useful for local-only development.
# Generate with:  openssl rand -hex 32
DASHBOARD_API_KEY=

# LiteLLM provider id used by the bundled opencode CLI.
# Common values: ollama, openai, anthropic, vllm, sglang, lm-studio
OPENCODE_PROVIDER=ollama

# Where opencode reaches the model.
# - macOS / Windows Docker Desktop: host.docker.internal works out of the box.
# - Linux: the compose file maps host.docker.internal via extra_hosts; this
#   keeps the same default URL working on Docker Engine 20.10+.
OPENCODE_BASE_URL=http://host.docker.internal:11434

# Required only for cloud providers (e.g. anthropic, openai). Leave blank
# when running everything against a local model endpoint.
OPENCODE_API_KEY=
