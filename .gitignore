# ---------- Python ----------
__pycache__/
*.pyc
*.pyo
*.pyd

# Virtualenv
.venv/
venv/
env/

# Build / packaging artefacts (regenerated by pip install -e / python -m build)
*.egg-info/
*.egg
build/
dist/

# Test / lint caches
.pytest_cache/
.coverage
htmlcov/
.mypy_cache/
.ruff_cache/
.tox/

# ---------- Environment / secrets ----------
.env
.env.*
!.env.example

# ---------- Symphony runtime artefacts ----------
# Per-issue agent workspaces (regenerated each run, may contain checkout/clones)
workspaces/
# Per-deployment WORKFLOW.md copy (the repo ships examples/WORKFLOW*.md
# instead — operators cp one of those to ./WORKFLOW.md to activate)
/WORKFLOW.md
# Dashboard SQLite (event/hint/override store, not a config artefact)
dashboard.db
*.db
*.db-wal
*.db-shm

# ---------- Project-specific ----------
logs/
bak/
.codex
CONVERSATION_HISTORY.md

# ---------- Frontend ----------
frontend/node_modules/
# Stray root-level node_modules (e.g. when a tool runs npm from the repo
# root by mistake — Vite caches under .vite there). Never source.
/node_modules/
frontend/dist/
frontend/*.tsbuildinfo
frontend/.vite/
frontend/coverage/
frontend/test-results/
frontend/playwright-report/
frontend/playwright/.cache/

# ---------- IDE / OS ----------
.vscode/
.idea/
.DS_Store
Thumbs.db
*.swp
*.swo
*~
