# syntax=docker/dockerfile:1.7
#
# Dev image — Symphony backend only.
#
# The production Dockerfile bakes the built SPA into one container; this dev
# variant skips that stage. Frontend dev runs on the *host* via
# `cd frontend && npm run dev`, which proxies REST + WebSocket back to this
# container on port 7957 (see frontend/vite.config.ts). Source code is
# bind-mounted from the host so edits are visible immediately — restart the
# container to pick them up (no auto-reload, by design).
#
# Build:    docker compose -f docker-compose.dev.yml build
# Run:      ./scripts/dev.sh up
# Docs:     docs/guide/docker-dev-environment.md

FROM python:3.12-slim AS dev

ENV PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    PIP_NO_CACHE_DIR=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1

# System deps:
#   - git + curl + ca-certificates: used by some dev workflows (gh, pre-commit, healthchecks)
#   - nodejs / npm: only needed if you run opencode-ai inside the dev container.
#     Kept here so Track-B opencode tests can also exercise the runner inline.
RUN apt-get update && apt-get install -y --no-install-recommends \
        git \
        curl \
        ca-certificates \
        nodejs \
        npm \
    && rm -rf /var/lib/apt/lists/*

RUN npm install -g opencode-ai

WORKDIR /app

# Pre-install Python deps so the layer caches across source edits. The actual
# source is bind-mounted at runtime; the COPY here is only what `pip install -e`
# needs to resolve the package metadata.
COPY pyproject.toml requirements.txt ./
COPY symphony_mvp/ ./symphony_mvp/
RUN pip install -e ".[dev,dashboard]"

# Data + workspace dirs live on bind mounts (see docker-compose.dev.yml).
RUN mkdir -p /app/data /app/workspaces /app/frontend/dist

EXPOSE 7957

# Default: run the same dashboard CLI as production, but pointed at the
# bind-mounted source. To restart after edits: `./scripts/dev.sh restart`.
CMD ["python", "-m", "symphony_mvp.dashboard", "/app/WORKFLOW.md", \
     "--host", "0.0.0.0", \
     "--port", "7957", \
     "--db", "/app/data/dashboard.db", \
     "-v"]
